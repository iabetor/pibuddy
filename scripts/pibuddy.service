[Unit]
Description=PiBuddy - Smart Voice Assistant
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=pi
Group=audio
WorkingDirectory=/opt/pibuddy
ExecStart=/opt/pibuddy/pibuddy -config /opt/pibuddy/configs/pibuddy.yaml
Restart=on-failure
RestartSec=5

# Environment — set API key here or in /home/pi/pibuddy/.env
EnvironmentFile=-/opt/pibuddy/.env

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=pibuddy

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/opt/pibuddy

# Allow audio device access
SupplementaryGroups=audio

[Install]
WantedBy=multi-user.target
